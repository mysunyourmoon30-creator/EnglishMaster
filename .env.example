# Copy to .env for local Docker Compose testing.
# These values are development-only examples. Do not use them for production.

ENGLISHMASTER_SQL_PASSWORD=change-this-local-dev-password-123!
ENGLISHMASTER_SQL_PORT=14333
ENGLISHMASTER_API_PORT=7001
ENGLISHMASTER_WEB_PORT=7002

# Optional: when both values are set, the API startup seed creates a local SuperAdmin.
ENGLISHMASTER_SUPERADMIN_EMAIL=dev.admin@englishmaster.local
ENGLISHMASTER_SUPERADMIN_PASSWORD=replace-with-a-local-development-password

# Demo content seed for local development.
ENGLISHMASTER_DEVELOPMENT_SEED_ENABLED=true

# Optional local-staging Compose values.
# Copy to a private .env file and replace these placeholders before running docker-compose.staging.yml.
ASPNETCORE_ENVIRONMENT=Staging
ENGLISHMASTER_STAGING_SQL_PASSWORD=Replace_this_staging_password_123!
ENGLISHMASTER_STAGING_SQL_PORT=14334
ENGLISHMASTER_STAGING_DATABASE=EnglishMasterStaging
ENGLISHMASTER_STAGING_API_PORT=7101
ENGLISHMASTER_STAGING_WEB_PORT=7102
ENGLISHMASTER_STAGING_ALLOWED_HOSTS=localhost;127.0.0.1
ENGLISHMASTER_STAGING_API_BASE_URL=http://englishmaster-staging-api:8080/
ENGLISHMASTER_STAGING_DEVELOPMENT_SEED_ENABLED=false
ENGLISHMASTER_STAGING_SUPERADMIN_EMAIL=
ENGLISHMASTER_STAGING_SUPERADMIN_PASSWORD=
ENGLISHMASTER_STAGING_MEDIA_PATH=/app/media
ENGLISHMASTER_STAGING_PUBLISHING_PATH=/app/publishing
ENGLISHMASTER_STAGING_EMAIL_PROVIDER=Development
ENGLISHMASTER_STAGING_EMAIL_FROM=

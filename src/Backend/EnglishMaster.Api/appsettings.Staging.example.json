{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<staging-sql-server>,1433;Database=EnglishMasterStaging;User Id=<sql-user>;Password=<sql-password>;Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true"
  },
  "DevelopmentSeed": {
    "Enabled": false
  },
  "Auth": {
    "InitialSuperAdmin": {
      "Email": "",
      "Password": ""
    }
  },
  "Publishing": {
    "LocalStoragePath": "/var/englishmaster/staging/publishing"
  },
  "Media": {
    "LocalStoragePath": "/var/englishmaster/staging/media"
  },
  "Email": {
    "Provider": "Smtp",
    "FromEmail": "noreply@staging.example.com",
    "FromName": "EnglishMaster Staging",
    "Smtp": {
      "Host": "<smtp-host>",
      "Port": 587,
      "UseSsl": true,
      "UserName": "<smtp-username>",
      "Password": "<set-from-secret>"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "<staging-api-host>"
}

@page "/learn"

<PageTitle>Learn</PageTitle>

<section class="page-header">
    <div>
        <h1>Learn</h1>
        <p class="muted">Open learner tools and public discovery pages.</p>
    </div>
    <a class="button" href="/learn/dashboard">Dashboard</a>
</section>

<section class="content-section">
    <h2>Learning Tools</h2>
    <div class="card-grid">
        <a class="list-card" href="/learn/recommendations"><h3>Recommendations</h3><p class="muted">Continue learning and review suggested content.</p></a>
        <a class="list-card" href="/learn/practice"><h3>Practice</h3><p class="muted">Review due practice items.</p></a>
        <a class="list-card" href="/learn/goals"><h3>Goals</h3><p class="muted">Track learning goals.</p></a>
        <a class="list-card" href="/learn/reports"><h3>Reports</h3><p class="muted">Review weekly learning reports.</p></a>
    </div>
</section>

<section class="content-section">
    <h2>Browse</h2>
    <div class="card-grid">
        <a class="list-card" href="/search?type=course"><h3>Courses</h3><p class="muted">Find published courses.</p></a>
        <a class="list-card" href="/search?type=lesson"><h3>Lessons</h3><p class="muted">Find published lessons.</p></a>
        <a class="list-card" href="/search?type=word"><h3>Dictionary</h3><p class="muted">Find vocabulary entries.</p></a>
        <a class="list-card" href="/search?type=grammar"><h3>Grammar</h3><p class="muted">Find grammar topics.</p></a>
    </div>
</section>

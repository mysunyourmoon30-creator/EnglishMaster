@page "/admin/content-quality/rules/create"
@rendermode InteractiveServer
@inject IContentQualityApiClient ContentQualityApiClient
@inject NavigationManager Navigation

<PageTitle>Create Quality Rule</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Create Quality Rule</h1>
    </div>
</section>

<EditForm Model="model" OnValidSubmit="SaveAsync" class="panel form-grid">
    <DataAnnotationsValidator />
    <label><span>Code</span><InputText class="input" @bind-Value="model.Code" /></label>
    <label><span>Name</span><InputText class="input" @bind-Value="model.Name" /></label>
    <label><span>Content Type</span><InputText class="input" @bind-Value="model.ContentType" /></label>
    <label><span>Severity</span><InputText class="input" @bind-Value="model.Severity" /></label>
    <label><span>Description</span><InputTextArea class="input" @bind-Value="model.Description" /></label>
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }
    <button class="button" type="submit">Save</button>
</EditForm>

@code {
    private RuleModel model = new();
    private string? errorMessage;

    private async Task SaveAsync()
    {
        try
        {
            await ContentQualityApiClient.CreateRuleAsync(new(model.Code, model.Name, model.Description, model.ContentType, model.Severity), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.ContentQuality.Rules);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private sealed class RuleModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ContentType { get; set; } = "Word";
        public string Severity { get; set; } = "Warning";
    }
}

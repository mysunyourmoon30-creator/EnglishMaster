@page "/admin/content-quality/rules"
@rendermode InteractiveServer
@inject IContentQualityApiClient ContentQualityApiClient

<PageTitle>Quality Rules</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Quality Rules</h1>
    </div>
    <div class="actions">
        <a class="button" href="@AdminRoutes.ContentQuality.CreateRule">Create</a>
    </div>
</section>

@if (isLoading)
{
    <div class="panel">Loading rules...</div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}
else
{
    <section class="content-list">
        @foreach (var rule in rules)
        {
            <article class="panel">
                <div class="item-header">
                    <div>
                        <h2>@rule.Code</h2>
                        <p>@rule.Name</p>
                    </div>
                    <span class="badge">@rule.Severity</span>
                </div>
                <a class="button small" href="@AdminRoutes.ContentQuality.EditRule(rule.Id)">Edit</a>
            </article>
        }
    </section>
}

@code {
    private IReadOnlyCollection<ContentQualityRuleDto> rules = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            rules = (await ContentQualityApiClient.SearchRulesAsync(null, null, null, CancellationToken.None)).Items;
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}

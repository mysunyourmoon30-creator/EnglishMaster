@using EnglishMaster.Contracts.LearningRecommendations

<section class="content-section">
    <h2>@Title</h2>
    @if (Items.Count == 0)
    {
        <p class="muted">No recommendations yet.</p>
    }
    else
    {
        <div class="card-grid">
            @foreach (var item in Items)
            {
                <article class="list-card">
                    <div>
                        <span class="pill">@item.ContentType</span>
                        @if (!string.IsNullOrWhiteSpace(item.CefrLevel))
                        {
                            <span class="pill">@item.CefrLevel</span>
                        }
                    </div>
                    <h3><a href="@item.Url">@item.Title</a></h3>
                    <p>@item.Summary</p>
                    <p class="muted">@item.ReasonText</p>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public IReadOnlyCollection<LearningRecommendationDto> Items { get; set; } = [];
}


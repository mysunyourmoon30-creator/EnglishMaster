@page "/admin/categories/{Id:guid}/edit"
@rendermode InteractiveServer
@inject ICategoriesApiClient CategoriesApiClient
@inject NavigationManager Navigation

<PageTitle>Edit Category</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Vocabulary</p>
        <h1>Edit Category</h1>
    </div>
</section>

@if (isLoading)
{
    <p class="muted">Loading category...</p>
}
else if (notFound)
{
    <section class="panel">
        <p class="muted">Category was not found.</p>
        <a class="button" href="@AdminRoutes.Categories.Index">Back to Categories</a>
    </section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="panel">
        <CategoryForm Model="model"
                      ValidationErrors="validationErrors"
                      IsSaving="isSaving"
                      ShowActiveToggle="true"
                      SubmitText="Save"
                      OnValidSubmit="SaveAsync" />
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CategoryFormModel model = new();
    private IReadOnlyDictionary<string, string[]> validationErrors = new Dictionary<string, string[]>();
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool notFound;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        notFound = false;
        errorMessage = null;

        try
        {
            var category = await CategoriesApiClient.GetAsync(Id, CancellationToken.None);
            if (category is null)
            {
                notFound = true;
                return;
            }

            model = CategoryFormModel.FromDto(category);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        validationErrors = new Dictionary<string, string[]>();

        try
        {
            await CategoriesApiClient.UpdateAsync(Id, model.ToUpdateRequest(), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.Categories.Index);
        }
        catch (ApiRequestException exception)
        {
            validationErrors = exception.ValidationErrors;
            errorMessage = validationErrors.Count == 0 ? exception.Message : null;
        }
        finally
        {
            isSaving = false;
        }
    }
}

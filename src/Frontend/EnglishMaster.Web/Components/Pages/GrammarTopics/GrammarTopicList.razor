@page "/admin/grammar-topics"
@rendermode InteractiveServer
@inject IGrammarApiClient GrammarApiClient

<PageTitle>Grammar Topics</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Grammar</p>
        <h1>Grammar Topics</h1>
    </div>
    <a class="button primary" href="@AdminRoutes.GrammarTopics.Create">New Topic</a>
</section>

<section class="panel">
    <form class="filters-grid" @onsubmit="SearchAsync" @onsubmit:preventDefault>
        <label>
            <span>Search</span>
            <input class="input" @bind="search" @bind:event="oninput" />
        </label>
        <label>
            <span>CEFR</span>
            <select class="input" @bind="cefrLevel">
                <option value="">All</option>
                @foreach (var level in CefrLevels)
                {
                    <option value="@level">@level</option>
                }
            </select>
        </label>
        <label>
            <span>Status</span>
            <select class="input" @bind="activeFilter">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
                <option value="">All</option>
            </select>
        </label>
        <label>
            <span>Page Size</span>
            <select class="input" @bind="pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
        <button class="button" type="submit">Search</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading grammar topics...</p>
}
else if (topics.Count == 0)
{
    <section class="panel">
        <p class="muted">No grammar topics found.</p>
    </section>
}
else
{
    <section class="table-wrap">
        <div class="pagination-summary">
            <span class="muted">Showing page @searchResult.PageNumber of @searchResult.TotalPages (@searchResult.TotalCount topics)</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>CEFR</th>
                    <th>Sort</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var topic in topics)
                {
                    <tr>
                        <td>
                            <strong>@topic.Title</strong>
                            <span class="muted">@topic.Summary</span>
                        </td>
                        <td>@topic.CefrLevel</td>
                        <td>@topic.SortOrder</td>
                        <td>@(topic.IsActive ? "Active" : "Inactive")</td>
                        <td class="row-actions">
                            <a class="button small" href="@AdminRoutes.GrammarTopics.Detail(topic.Id)">View</a>
                            <a class="button small" href="@AdminRoutes.GrammarTopics.Edit(topic.Id)">Edit</a>
                            <a class="button small" href="@AdminRoutes.GrammarRules.IndexForTopic(topic.Id)">Rules</a>
                            <button class="button small danger" type="button" @onclick="() => DeleteAsync(topic.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-row">
            <button class="button small" type="button" disabled="@(!searchResult.HasPreviousPage)" @onclick="PreviousPageAsync">Previous</button>
            <span class="muted">Page @searchResult.PageNumber</span>
            <button class="button small" type="button" disabled="@(!searchResult.HasNextPage)" @onclick="NextPageAsync">Next</button>
        </div>
    </section>
}

@code {
    private static readonly string[] CefrLevels = ["A1", "A2", "B1", "B2", "C1", "C2"];

    private IReadOnlyCollection<GrammarTopicDto> topics = [];
    private GrammarTopicSearchResponse searchResult = EmptySearchResult();
    private string? search;
    private string? cefrLevel;
    private string activeFilter = "true";
    private int pageNumber = 1;
    private int pageSize = 10;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            searchResult = await GrammarApiClient.SearchTopicsAsync(
                new GrammarTopicSearchRequest(
                    search,
                    string.IsNullOrWhiteSpace(cefrLevel) ? null : cefrLevel,
                    ParseActiveFilter(),
                    pageNumber,
                    pageSize),
                CancellationToken.None);
            topics = searchResult.Items;
        }
        catch (ApiRequestException exception)
        {
            searchResult = EmptySearchResult();
            topics = [];
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (!searchResult.HasPreviousPage)
        {
            return;
        }

        pageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!searchResult.HasNextPage)
        {
            return;
        }

        pageNumber++;
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        errorMessage = null;

        try
        {
            await GrammarApiClient.DeleteTopicAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private bool? ParseActiveFilter()
    {
        return activeFilter switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };
    }

    private static GrammarTopicSearchResponse EmptySearchResult()
    {
        return new GrammarTopicSearchResponse([], 1, 10, 0, 0, false, false);
    }
}

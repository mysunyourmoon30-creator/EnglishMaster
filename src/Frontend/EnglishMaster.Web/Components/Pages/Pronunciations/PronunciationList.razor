@page "/admin/pronunciations"
@rendermode InteractiveServer
@inject IPronunciationsApiClient PronunciationsApiClient

<PageTitle>Pronunciations</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Pronunciation</p>
        <h1>Pronunciations</h1>
    </div>
    <a class="button primary" href="@AdminRoutes.Pronunciations.Create">New Pronunciation</a>
</section>

<section class="panel">
    <form class="filters-grid" @onsubmit="SearchAsync" @onsubmit:preventDefault>
        <label>
            <span>Search</span>
            <input class="input" @bind="search" @bind:event="oninput" />
        </label>
        <label>
            <span>Status</span>
            <select class="input" @bind="activeFilter">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
                <option value="">All</option>
            </select>
        </label>
        <label>
            <span>Page Size</span>
            <select class="input" @bind="pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
        <button class="button" type="submit">Search</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading pronunciations...</p>
}
else if (pronunciations.Count == 0)
{
    <section class="panel">
        <p class="muted">No pronunciations found.</p>
    </section>
}
else
{
    <section class="table-wrap">
        <div class="pagination-summary">
            <span class="muted">Showing page @searchResult.PageNumber of @searchResult.TotalPages (@searchResult.TotalCount pronunciations)</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Word</th>
                    <th>IPA UK</th>
                    <th>IPA US</th>
                    <th>Thai Reading</th>
                    <th>Media</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pronunciation in pronunciations)
                {
                    <tr>
                        <td>
                            <strong>@(pronunciation.Word?.Text ?? pronunciation.WordId.ToString())</strong>
                            @if (pronunciation.Word is not null)
                            {
                                <span class="muted">@pronunciation.Word.Slug</span>
                            }
                        </td>
                        <td>@pronunciation.IpaUk</td>
                        <td>@pronunciation.IpaUs</td>
                        <td>@pronunciation.ThaiReading</td>
                        <td>@FormatMedia(pronunciation)</td>
                        <td>@(pronunciation.IsActive ? "Active" : "Inactive")</td>
                        <td class="row-actions">
                            <a class="button small" href="@AdminRoutes.Pronunciations.Detail(pronunciation.Id)">View</a>
                            <a class="button small" href="@AdminRoutes.Pronunciations.Edit(pronunciation.Id)">Edit</a>
                            <button class="button small danger" type="button" @onclick="() => DeleteAsync(pronunciation.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-row">
            <button class="button small" type="button" disabled="@(!searchResult.HasPreviousPage)" @onclick="PreviousPageAsync">Previous</button>
            <span class="muted">Page @searchResult.PageNumber</span>
            <button class="button small" type="button" disabled="@(!searchResult.HasNextPage)" @onclick="NextPageAsync">Next</button>
        </div>
    </section>
}

@code {
    private IReadOnlyCollection<PronunciationDto> pronunciations = [];
    private PronunciationSearchResponse searchResult = EmptySearchResult();
    private string? search;
    private string activeFilter = "true";
    private int pageNumber = 1;
    private int pageSize = 10;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            searchResult = await PronunciationsApiClient.SearchAsync(
                new PronunciationSearchRequest(
                    search,
                    WordId: null,
                    ParseActiveFilter(),
                    pageNumber,
                    pageSize),
                CancellationToken.None);
            pronunciations = searchResult.Items;
        }
        catch (ApiRequestException exception)
        {
            searchResult = EmptySearchResult();
            pronunciations = [];
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (!searchResult.HasPreviousPage)
        {
            return;
        }

        pageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!searchResult.HasNextPage)
        {
            return;
        }

        pageNumber++;
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        errorMessage = null;

        try
        {
            await PronunciationsApiClient.DeleteAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private bool? ParseActiveFilter()
    {
        return activeFilter switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };
    }

    private static string FormatMedia(PronunciationDto pronunciation)
    {
        var items = new List<string>();
        if (pronunciation.AudioSlowMedia is not null)
        {
            items.Add("Slow audio");
        }

        if (pronunciation.AudioNormalMedia is not null)
        {
            items.Add("Normal audio");
        }

        if (pronunciation.MouthImageMedia is not null)
        {
            items.Add("Mouth image");
        }

        return items.Count == 0 ? "-" : string.Join(", ", items);
    }

    private static PronunciationSearchResponse EmptySearchResult()
    {
        return new PronunciationSearchResponse([], 1, 10, 0, 0, false, false);
    }
}

@page "/admin/lessons/{Id:guid}/edit"
@rendermode InteractiveServer
@inject ILessonApiClient LessonApiClient
@inject ICategoriesApiClient CategoriesApiClient
@inject IMediaApiClient MediaApiClient
@inject NavigationManager Navigation

<PageTitle>Edit Lesson</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Lessons</p>
        <h1>Edit Lesson</h1>
    </div>
</section>

@if (isLoading)
{
    <p class="muted">Loading lesson...</p>
}
else if (notFound)
{
    <section class="panel">
        <p class="muted">Lesson was not found.</p>
        <a class="button" href="@AdminRoutes.Lessons.Index">Back to Lessons</a>
    </section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="panel">
        <LessonForm Model="model"
                    Categories="categories"
                    ThumbnailMediaOptions="thumbnailMediaOptions"
                    ValidationErrors="validationErrors"
                    IsSaving="isSaving"
                    ShowStatusToggles="true"
                    SubmitText="Save"
                    OnValidSubmit="SaveAsync" />
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private LessonFormModel model = new();
    private IReadOnlyCollection<CategoryDto> categories = [];
    private IReadOnlyCollection<MediaDto> thumbnailMediaOptions = [];
    private IReadOnlyDictionary<string, string[]> validationErrors = new Dictionary<string, string[]>();
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool notFound;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        notFound = false;
        errorMessage = null;

        try
        {
            categories = (await CategoriesApiClient.SearchAsync(search: null, isActive: true, CancellationToken.None)).Items;
            thumbnailMediaOptions = (await MediaApiClient.SearchAsync(
                new MediaSearchRequest(MediaType: "Image", IsActive: true, PageSize: 100),
                CancellationToken.None)).Items;

            var lesson = await LessonApiClient.GetAsync(Id, CancellationToken.None);
            if (lesson is null)
            {
                notFound = true;
                return;
            }

            model = LessonFormModel.FromDto(lesson);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        validationErrors = new Dictionary<string, string[]>();

        try
        {
            await LessonApiClient.UpdateAsync(Id, model.ToUpdateRequest(), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.Lessons.Detail(Id));
        }
        catch (ApiRequestException exception)
        {
            validationErrors = exception.ValidationErrors;
            errorMessage = validationErrors.Count == 0 ? exception.Message : null;
        }
        finally
        {
            isSaving = false;
        }
    }
}

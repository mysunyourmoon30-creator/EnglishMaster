@page "/admin/grammar-examples/{Id:guid}/edit"
@rendermode InteractiveServer
@inject IGrammarApiClient GrammarApiClient
@inject NavigationManager Navigation

<PageTitle>Edit Grammar Example</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Grammar</p>
        <h1>Edit Grammar Example</h1>
    </div>
</section>

@if (isLoading)
{
    <p class="muted">Loading grammar example...</p>
}
else if (notFound)
{
    <section class="panel">
        <p class="muted">Grammar example was not found.</p>
        <a class="button" href="@AdminRoutes.GrammarRules.Index">Back to Rules</a>
    </section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert error">@errorMessage</div>
    }

    <section class="panel">
        <GrammarExampleForm Model="model"
                            ValidationErrors="validationErrors"
                            IsSaving="isSaving"
                            ShowActiveToggle="true"
                            SubmitText="Save"
                            OnValidSubmit="SaveAsync"
                            OnCancel="CancelAsync" />
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private GrammarExampleFormModel model = new();
    private Guid grammarRuleId;
    private IReadOnlyDictionary<string, string[]> validationErrors = new Dictionary<string, string[]>();
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool notFound;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        notFound = false;
        errorMessage = null;

        try
        {
            var example = await GrammarApiClient.GetExampleAsync(Id, CancellationToken.None);
            if (example is null)
            {
                notFound = true;
                return;
            }

            grammarRuleId = example.GrammarRuleId;
            model = GrammarExampleFormModel.FromDto(example);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        validationErrors = new Dictionary<string, string[]>();

        try
        {
            await GrammarApiClient.UpdateExampleAsync(Id, model.ToUpdateRequest(), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.GrammarRules.Detail(grammarRuleId));
        }
        catch (ApiRequestException exception)
        {
            validationErrors = exception.ValidationErrors;
            errorMessage = validationErrors.Count == 0 ? exception.Message : null;
        }
        finally
        {
            isSaving = false;
        }
    }

    private Task CancelAsync()
    {
        Navigation.NavigateTo(AdminRoutes.GrammarRules.Detail(grammarRuleId));
        return Task.CompletedTask;
    }
}

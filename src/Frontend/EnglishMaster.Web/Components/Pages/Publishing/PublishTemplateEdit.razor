@page "/admin/publishing/templates/{Id:guid}/edit"
@rendermode InteractiveServer
@inject IPublishingApiClient PublishingApiClient
@inject NavigationManager NavigationManager

<PageTitle>Edit Publish Template</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Publishing</p>
        <h1>Edit Publish Template</h1>
    </div>
    <a class="button" href="@AdminRoutes.Publishing.Templates.Index">Back</a>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading template...</p>
}
else if (notFound)
{
    <section class="panel">
        <p class="muted">Publish template was not found.</p>
    </section>
}
else
{
    <section class="panel">
        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="form-grid">
                <label>
                    <span>Name</span>
                    <InputText class="input" @bind-Value="model.Name" />
                </label>
                <label>
                    <span>Format</span>
                    <InputSelect class="input" @bind-Value="model.Format">
                        @foreach (var item in Formats)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </label>
                <label>
                    <span>Description</span>
                    <InputText class="input" @bind-Value="model.Description" />
                </label>
                <label>
                    <InputCheckbox @bind-Value="model.IsDefault" />
                    <span>Default template</span>
                </label>
                <label>
                    <InputCheckbox @bind-Value="model.IsActive" />
                    <span>Active</span>
                </label>
            </div>
            <label>
                <span>Template Content</span>
                <InputTextArea class="input" @bind-Value="model.TemplateContent" />
            </label>
            <div class="form-actions">
                <button class="button primary" type="submit" disabled="@isSaving">@(isSaving ? "Saving..." : "Save")</button>
            </div>
        </EditForm>
    </section>
}

@code {
    private static readonly string[] Formats = ["Html", "Pdf", "Docx", "Markdown"];

    [Parameter]
    public Guid Id { get; set; }

    private PublishTemplateFormModel model = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool notFound;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var template = await PublishingApiClient.GetTemplateAsync(Id, CancellationToken.None);
            if (template is null)
            {
                notFound = true;
            }
            else
            {
                model = PublishTemplateFormModel.FromDto(template);
            }
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            await PublishingApiClient.UpdateTemplateAsync(Id, model.ToUpdateRequest(), CancellationToken.None);
            NavigationManager.NavigateTo(AdminRoutes.Publishing.Templates.Index);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
}

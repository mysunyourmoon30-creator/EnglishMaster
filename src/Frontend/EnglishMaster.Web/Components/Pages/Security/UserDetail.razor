@page "/admin/users/{Id:guid}"
@rendermode InteractiveServer
@inject ISecurityApiClient SecurityApiClient

<PageTitle>User Detail</PageTitle>

@if (isLoading)
{
    <p class="muted">Loading user...</p>
}
else if (user is null)
{
    <section class="panel"><p class="muted">User was not found.</p></section>
}
else
{
    <section class="page-header">
        <div>
            <p class="eyebrow">Administration</p>
            <h1>@user.DisplayName</h1>
        </div>
        <a class="button primary" href="@AdminRoutes.Users.Edit(user.Id)">Edit</a>
    </section>
    <section class="panel detail-grid">
        <div><span class="muted">Email</span><strong>@user.Email</strong></div>
        <div><span class="muted">User Name</span><strong>@user.UserName</strong></div>
        <div><span class="muted">Status</span><strong>@(user.IsActive ? "Active" : "Inactive")</strong></div>
        <div><span class="muted">Roles</span><strong>@string.Join(", ", user.Roles.Select(role => role.Name))</strong></div>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private UserDto? user;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        user = await SecurityApiClient.GetUserAsync(Id, CancellationToken.None);
        isLoading = false;
    }
}

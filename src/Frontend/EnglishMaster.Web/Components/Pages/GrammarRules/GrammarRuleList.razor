@page "/admin/grammar-rules"
@rendermode InteractiveServer
@inject IGrammarApiClient GrammarApiClient

<PageTitle>Grammar Rules</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Grammar</p>
        <h1>Grammar Rules</h1>
    </div>
    <a class="button primary" href="@AdminRoutes.GrammarRules.Create">New Rule</a>
</section>

<section class="panel">
    <form class="filters-grid" @onsubmit="SearchAsync" @onsubmit:preventDefault>
        <label>
            <span>Search</span>
            <input class="input" @bind="search" @bind:event="oninput" />
        </label>
        <label>
            <span>Topic</span>
            <select class="input" @bind="selectedTopicId">
                <option value="">All topics</option>
                @foreach (var topic in topics)
                {
                    <option value="@topic.Id">@topic.Title</option>
                }
            </select>
        </label>
        <label>
            <span>Status</span>
            <select class="input" @bind="activeFilter">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
                <option value="">All</option>
            </select>
        </label>
        <label>
            <span>Page Size</span>
            <select class="input" @bind="pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
        <button class="button" type="submit">Search</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading grammar rules...</p>
}
else if (rules.Count == 0)
{
    <section class="panel">
        <p class="muted">No grammar rules found.</p>
    </section>
}
else
{
    <section class="table-wrap">
        <div class="pagination-summary">
            <span class="muted">Showing page @searchResult.PageNumber of @searchResult.TotalPages (@searchResult.TotalCount rules)</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Rule</th>
                    <th>Topic</th>
                    <th>Sort</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in rules)
                {
                    <tr>
                        <td>
                            <strong>@rule.Title</strong>
                            <span class="muted">@rule.StructurePattern</span>
                        </td>
                        <td>@(rule.Topic?.Title ?? rule.GrammarTopicId.ToString())</td>
                        <td>@rule.SortOrder</td>
                        <td>@(rule.IsActive ? "Active" : "Inactive")</td>
                        <td class="row-actions">
                            <a class="button small" href="@AdminRoutes.GrammarRules.Detail(rule.Id)">View</a>
                            <a class="button small" href="@AdminRoutes.GrammarRules.Edit(rule.Id)">Edit</a>
                            <button class="button small danger" type="button" @onclick="() => DeleteAsync(rule.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-row">
            <button class="button small" type="button" disabled="@(!searchResult.HasPreviousPage)" @onclick="PreviousPageAsync">Previous</button>
            <span class="muted">Page @searchResult.PageNumber</span>
            <button class="button small" type="button" disabled="@(!searchResult.HasNextPage)" @onclick="NextPageAsync">Next</button>
        </div>
    </section>
}

@code {
    private IReadOnlyCollection<GrammarTopicDto> topics = [];
    private IReadOnlyCollection<GrammarRuleDto> rules = [];
    private GrammarRuleSearchResponse searchResult = EmptySearchResult();
    private string? search;
    private Guid? selectedTopicId;
    private string activeFilter = "true";
    private int pageNumber = 1;
    private int pageSize = 10;
    private string? errorMessage;
    private bool isLoading = true;

    [SupplyParameterFromQuery(Name = "topicId")]
    public Guid? TopicId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        selectedTopicId = TopicId;
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            topics = (await GrammarApiClient.SearchTopicsAsync(
                new GrammarTopicSearchRequest(IsActive: true, PageSize: 100),
                CancellationToken.None)).Items;
            searchResult = await GrammarApiClient.SearchRulesAsync(
                new GrammarRuleSearchRequest(
                    search,
                    selectedTopicId,
                    ParseActiveFilter(),
                    pageNumber,
                    pageSize),
                CancellationToken.None);
            rules = searchResult.Items;
        }
        catch (ApiRequestException exception)
        {
            searchResult = EmptySearchResult();
            rules = [];
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (!searchResult.HasPreviousPage)
        {
            return;
        }

        pageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!searchResult.HasNextPage)
        {
            return;
        }

        pageNumber++;
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        errorMessage = null;

        try
        {
            await GrammarApiClient.DeleteRuleAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private bool? ParseActiveFilter()
    {
        return activeFilter switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };
    }

    private static GrammarRuleSearchResponse EmptySearchResult()
    {
        return new GrammarRuleSearchResponse([], 1, 10, 0, 0, false, false);
    }
}

@page "/admin/words"
@rendermode InteractiveServer
@inject IWordsApiClient WordsApiClient
@inject ICategoriesApiClient CategoriesApiClient
@inject ITagsApiClient TagsApiClient

<PageTitle>Words</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Vocabulary</p>
        <h1>Words</h1>
    </div>
    <a class="button primary" href="@AdminRoutes.Words.Create">New Word</a>
</section>

<section class="panel">
    <form class="filters-grid" @onsubmit="SearchAsync" @onsubmit:preventDefault>
        <label>
            <span>Search</span>
            <input class="input" @bind="search" @bind:event="oninput" />
        </label>
        <label>
            <span>CEFR</span>
            <select class="input" @bind="cefrLevel">
                <option value="">All levels</option>
                @foreach (var option in CefrLevelOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
        <label>
            <span>Part of Speech</span>
            <select class="input" @bind="partOfSpeech">
                <option value="">All parts</option>
                @foreach (var option in PartOfSpeechOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
        <label>
            <span>Status</span>
            <select class="input" @bind="activeFilter">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </label>
        <label>
            <span>Category</span>
            <select class="input" @bind="categoryFilter">
                <option value="">All categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Tag</span>
            <select class="input" @bind="tagFilter">
                <option value="">All tags</option>
                @foreach (var tag in tags)
                {
                    <option value="@tag.Id">@tag.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Sort By</span>
            <select class="input" @bind="sortBy">
                <option value="Text">Text</option>
                <option value="CreatedAt">Created</option>
            </select>
        </label>
        <label>
            <span>Direction</span>
            <select class="input" @bind="sortDirection">
                <option value="Asc">Ascending</option>
                <option value="Desc">Descending</option>
            </select>
        </label>
        <label>
            <span>Page Size</span>
            <select class="input" @bind="pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
        <button class="button" type="submit">Search</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading words...</p>
}
else if (words.Count == 0)
{
    <section class="panel">
        <p class="muted">No words found.</p>
    </section>
}
else
{
    <section class="table-wrap">
        <div class="pagination-summary">
            <span class="muted">Showing page @searchResult.PageNumber of @searchResult.TotalPages (@searchResult.TotalCount words)</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Text</th>
                    <th>Slug</th>
                    <th>Meaning EN</th>
                    <th>Category</th>
                    <th>Tags</th>
                    <th>Media</th>
                    <th>Part</th>
                    <th>CEFR</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var word in words)
                {
                    <tr>
                        <td>
                            <strong>@word.Text</strong>
                            <span class="muted">@word.IpaUk</span>
                        </td>
                        <td>@word.Slug</td>
                        <td>@word.MeaningEn</td>
                        <td>@(word.Category?.Name ?? "-")</td>
                        <td>@FormatTags(word.Tags)</td>
                        <td>@FormatMedia(word)</td>
                        <td>@word.PartOfSpeech</td>
                        <td>@word.CefrLevel</td>
                        <td>@(word.IsActive ? "Active" : "Inactive")</td>
                        <td class="row-actions">
                            <a class="button small" href="@AdminRoutes.Words.Detail(word.Id)">View</a>
                            <a class="button small" href="@AdminRoutes.Words.Edit(word.Id)">Edit</a>
                            <button class="button small danger" type="button" @onclick="() => DeleteAsync(word.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-row">
            <button class="button small" type="button" disabled="@(!searchResult.HasPreviousPage)" @onclick="PreviousPageAsync">Previous</button>
            <span class="muted">Page @searchResult.PageNumber</span>
            <button class="button small" type="button" disabled="@(!searchResult.HasNextPage)" @onclick="NextPageAsync">Next</button>
        </div>
    </section>
}

@code {
    private static readonly string[] PartOfSpeechOptions =
    [
        "Noun",
        "Pronoun",
        "Verb",
        "Adjective",
        "Adverb",
        "Preposition",
        "Conjunction",
        "Interjection",
        "Determiner",
        "Phrase",
        "Other"
    ];

    private static readonly string[] CefrLevelOptions = ["A1", "A2", "B1", "B2", "C1", "C2"];

    private IReadOnlyCollection<WordDto> words = [];
    private IReadOnlyCollection<CategoryDto> categories = [];
    private IReadOnlyCollection<TagDto> tags = [];
    private WordSearchResponse searchResult = EmptySearchResult();
    private string? search;
    private string? cefrLevel;
    private string? partOfSpeech;
    private string activeFilter = "true";
    private string? categoryFilter;
    private string? tagFilter;
    private string sortBy = "Text";
    private string sortDirection = "Asc";
    private int pageNumber = 1;
    private int pageSize = 10;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await LoadAsync();
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            categories = (await CategoriesApiClient.SearchAsync(null, true, CancellationToken.None)).Items;
            tags = (await TagsApiClient.SearchAsync(null, true, CancellationToken.None)).Items;
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            searchResult = await WordsApiClient.SearchAsync(
                new WordSearchRequest(
                    search,
                    string.IsNullOrWhiteSpace(cefrLevel) ? null : cefrLevel,
                    string.IsNullOrWhiteSpace(partOfSpeech) ? null : partOfSpeech,
                    activeFilter == "false" ? false : true,
                    ParseGuid(categoryFilter),
                    ParseGuid(tagFilter),
                    pageNumber,
                    pageSize,
                    sortBy,
                    sortDirection),
                CancellationToken.None);
            words = searchResult.Items;
        }
        catch (ApiRequestException exception)
        {
            searchResult = EmptySearchResult();
            words = [];
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (!searchResult.HasPreviousPage)
        {
            return;
        }

        pageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!searchResult.HasNextPage)
        {
            return;
        }

        pageNumber++;
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        errorMessage = null;

        try
        {
            await WordsApiClient.DeleteAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static WordSearchResponse EmptySearchResult()
    {
        return new WordSearchResponse([], 1, 10, 0, 0, false, false);
    }

    private static Guid? ParseGuid(string? value)
    {
        return Guid.TryParse(value, out var id) ? id : null;
    }

    private static string FormatTags(IReadOnlyCollection<WordTagDto> wordTags)
    {
        return wordTags.Count == 0
            ? "-"
            : string.Join(", ", wordTags.Select(tag => tag.Name));
    }

    private static string FormatMedia(WordDto word)
    {
        var items = new List<string>();
        if (word.ImageMedia is not null)
        {
            items.Add("Image");
        }

        if (word.AudioMedia is not null)
        {
            items.Add("Audio");
        }

        return items.Count == 0 ? "-" : string.Join(", ", items);
    }
}

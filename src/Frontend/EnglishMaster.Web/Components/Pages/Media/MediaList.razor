@page "/admin/media"
@rendermode InteractiveServer
@inject IMediaApiClient MediaApiClient

<PageTitle>Media</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Assets</p>
        <h1>Media</h1>
    </div>
    <div class="actions">
        <a class="button" href="@AdminRoutes.Media.Upload">Upload</a>
        <a class="button primary" href="@AdminRoutes.Media.Create">New Media</a>
    </div>
</section>

<section class="panel">
    <form class="filters-grid" @onsubmit="SearchAsync" @onsubmit:preventDefault>
        <label>
            <span>Search</span>
            <input class="input" @bind="search" @bind:event="oninput" />
        </label>
        <label>
            <span>Media Type</span>
            <select class="input" @bind="mediaType">
                <option value="">All types</option>
                @foreach (var option in MediaTypeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
        <label>
            <span>Content Type</span>
            <input class="input" @bind="contentType" @bind:event="oninput" />
        </label>
        <label>
            <span>Status</span>
            <select class="input" @bind="activeFilter">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
                <option value="">All</option>
            </select>
        </label>
        <label>
            <span>Page Size</span>
            <select class="input" @bind="pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </label>
        <button class="button" type="submit">Search</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading media...</p>
}
else if (mediaItems.Count == 0)
{
    <section class="panel">
        <p class="muted">No media found.</p>
    </section>
}
else
{
    <section class="table-wrap">
        <div class="pagination-summary">
            <span class="muted">Showing page @searchResult.PageNumber of @searchResult.TotalPages (@searchResult.TotalCount media items)</span>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>File</th>
                    <th>Type</th>
                    <th>Content</th>
                    <th>Size</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var media in mediaItems)
                {
                    <tr>
                        <td>
                            <strong>@media.OriginalFileName</strong>
                            <span class="muted">@media.FileName</span>
                        </td>
                        <td>@media.MediaType</td>
                        <td>@media.ContentType</td>
                        <td>@FormatSize(media.FileSize)</td>
                        <td>@(media.IsActive ? "Active" : "Inactive")</td>
                        <td class="row-actions">
                            <a class="button small" href="@AdminRoutes.Media.Detail(media.Id)">View</a>
                            <a class="button small" href="@AdminRoutes.Media.Edit(media.Id)">Edit</a>
                            <button class="button small danger" type="button" @onclick="() => DeleteAsync(media.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination-row">
            <button class="button small" type="button" disabled="@(!searchResult.HasPreviousPage)" @onclick="PreviousPageAsync">Previous</button>
            <span class="muted">Page @searchResult.PageNumber</span>
            <button class="button small" type="button" disabled="@(!searchResult.HasNextPage)" @onclick="NextPageAsync">Next</button>
        </div>
    </section>
}

@code {
    private static readonly string[] MediaTypeOptions = ["Image", "Audio", "Video", "Document", "Other"];

    private IReadOnlyCollection<MediaDto> mediaItems = [];
    private MediaSearchResponse searchResult = EmptySearchResult();
    private string? search;
    private string? mediaType;
    private string? contentType;
    private string activeFilter = "true";
    private int pageNumber = 1;
    private int pageSize = 10;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            searchResult = await MediaApiClient.SearchAsync(
                new MediaSearchRequest(
                    search,
                    string.IsNullOrWhiteSpace(mediaType) ? null : mediaType,
                    string.IsNullOrWhiteSpace(contentType) ? null : contentType,
                    ParseActiveFilter(),
                    pageNumber,
                    pageSize),
                CancellationToken.None);
            mediaItems = searchResult.Items;
        }
        catch (ApiRequestException exception)
        {
            searchResult = EmptySearchResult();
            mediaItems = [];
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPageAsync()
    {
        if (!searchResult.HasPreviousPage)
        {
            return;
        }

        pageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!searchResult.HasNextPage)
        {
            return;
        }

        pageNumber++;
        await LoadAsync();
    }

    private async Task DeleteAsync(Guid id)
    {
        errorMessage = null;

        try
        {
            await MediaApiClient.DeleteAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
    }

    private bool? ParseActiveFilter()
    {
        return activeFilter switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };
    }

    private static MediaSearchResponse EmptySearchResult()
    {
        return new MediaSearchResponse([], 1, 10, 0, 0, false, false);
    }

    private static string FormatSize(long bytes)
    {
        return bytes < 1024
            ? $"{bytes} B"
            : $"{bytes / 1024d:0.##} KB";
    }
}

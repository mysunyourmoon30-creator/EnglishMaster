@page "/admin/media/create"
@rendermode InteractiveServer
@inject IMediaApiClient MediaApiClient
@inject NavigationManager Navigation

<PageTitle>New Media</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Assets</p>
        <h1>New Media</h1>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

<section class="panel">
    <MediaForm Model="model"
               ValidationErrors="validationErrors"
               IsSaving="isSaving"
               SubmitText="Create"
               OnValidSubmit="SaveAsync" />
</section>

@code {
    private readonly MediaFormModel model = new();
    private IReadOnlyDictionary<string, string[]> validationErrors = new Dictionary<string, string[]>();
    private string? errorMessage;
    private bool isSaving;

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        validationErrors = new Dictionary<string, string[]>();

        try
        {
            await MediaApiClient.CreateAsync(model.ToCreateRequest(), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.Media.Index);
        }
        catch (ApiRequestException exception)
        {
            validationErrors = exception.ValidationErrors;
            errorMessage = validationErrors.Count == 0 ? exception.Message : null;
        }
        finally
        {
            isSaving = false;
        }
    }
}

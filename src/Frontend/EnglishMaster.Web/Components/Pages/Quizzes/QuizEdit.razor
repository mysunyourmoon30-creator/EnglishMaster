@page "/admin/quizzes/{Id:guid}/edit"
@rendermode InteractiveServer
@inject IQuizApiClient QuizApiClient
@inject ICategoriesApiClient CategoriesApiClient
@inject ILessonApiClient LessonApiClient
@inject ICourseApiClient CourseApiClient
@inject IBookApiClient BookApiClient
@inject NavigationManager Navigation

<PageTitle>Edit Quiz</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Quizzes</p>
        <h1>Edit Quiz</h1>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert error">@errorMessage</div>
}

@if (isLoading)
{
    <p class="muted">Loading quiz...</p>
}
else if (notFound)
{
    <section class="panel">
        <p class="muted">Quiz was not found.</p>
    </section>
}
else
{
    <section class="panel">
        <QuizForm Model="model"
                  Categories="categories"
                  Lessons="lessons"
                  Courses="courses"
                  Books="books"
                  ValidationErrors="validationErrors"
                  IsSaving="isSaving"
                  ShowStatusToggles="true"
                  SubmitText="Save"
                  OnValidSubmit="SaveAsync" />
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private QuizFormModel model = new();
    private IReadOnlyCollection<CategoryDto> categories = [];
    private IReadOnlyCollection<LessonDto> lessons = [];
    private IReadOnlyCollection<CourseDto> courses = [];
    private IReadOnlyCollection<BookDto> books = [];
    private IReadOnlyDictionary<string, string[]> validationErrors = new Dictionary<string, string[]>();
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool notFound;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        notFound = false;
        errorMessage = null;

        try
        {
            categories = (await CategoriesApiClient.SearchAsync(search: null, isActive: true, CancellationToken.None)).Items;
            lessons = (await LessonApiClient.SearchAsync(
                new LessonSearchRequest(IsActive: true, PageSize: 100, SortBy: "Title", SortDirection: "Asc"),
                CancellationToken.None)).Items;
            courses = (await CourseApiClient.SearchAsync(
                new CourseSearchRequest(IsActive: true, PageSize: 100, SortBy: "Title", SortDirection: "Asc"),
                CancellationToken.None)).Items;
            books = (await BookApiClient.SearchAsync(
                new BookSearchRequest(IsActive: true, PageSize: 100, SortBy: "Title", SortDirection: "Asc"),
                CancellationToken.None)).Items;

            var quiz = await QuizApiClient.GetAsync(Id, CancellationToken.None);
            if (quiz is null)
            {
                notFound = true;
                return;
            }

            model = QuizFormModel.FromDto(quiz);
        }
        catch (ApiRequestException exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        validationErrors = new Dictionary<string, string[]>();

        try
        {
            var quiz = await QuizApiClient.UpdateAsync(Id, model.ToUpdateRequest(), CancellationToken.None);
            Navigation.NavigateTo(AdminRoutes.Quizzes.Detail(quiz.Id));
        }
        catch (ApiRequestException exception)
        {
            validationErrors = exception.ValidationErrors;
            errorMessage = validationErrors.Count == 0 ? exception.Message : null;
        }
        finally
        {
            isSaving = false;
        }
    }
}

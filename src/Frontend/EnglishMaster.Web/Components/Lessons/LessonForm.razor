@using EnglishMaster.Web.Services.Lessons

<EditForm Model="Model" OnValidSubmit="SubmitAsync" class="word-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ValidationErrors.Count > 0)
    {
        <div class="alert error">
            <ul>
                @foreach (var error in ValidationErrors.SelectMany(item => item.Value))
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-grid">
        <label class="span-2">
            <span>Title</span>
            <InputText class="input" @bind-Value="Model.Title" />
            <ValidationMessage For="@(() => Model.Title)" />
        </label>

        <label class="span-2">
            <span>Summary</span>
            <InputTextArea class="input textarea" @bind-Value="Model.Summary" />
            <ValidationMessage For="@(() => Model.Summary)" />
        </label>

        <label class="span-2">
            <span>Description</span>
            <InputTextArea class="input textarea" @bind-Value="Model.Description" />
            <ValidationMessage For="@(() => Model.Description)" />
        </label>

        <label>
            <span>CEFR</span>
            <InputSelect class="input" @bind-Value="Model.CefrLevel">
                <option value="">No level</option>
                @foreach (var level in CefrLevels)
                {
                    <option value="@level">@level</option>
                }
            </InputSelect>
        </label>

        <label>
            <span>Category</span>
            <InputSelect class="input" @bind-Value="Model.CategoryId">
                <option value="">No category</option>
                @foreach (var category in Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </InputSelect>
        </label>

        <label>
            <span>Thumbnail</span>
            <InputSelect class="input" @bind-Value="Model.ThumbnailMediaId">
                <option value="">No thumbnail</option>
                @foreach (var media in ThumbnailMediaOptions)
                {
                    <option value="@media.Id">@media.OriginalFileName</option>
                }
            </InputSelect>
        </label>

        <label>
            <span>Estimated Minutes</span>
            <InputNumber class="input" @bind-Value="Model.EstimatedMinutes" />
            <ValidationMessage For="@(() => Model.EstimatedMinutes)" />
        </label>

        <label>
            <span>Sort Order</span>
            <InputNumber class="input" @bind-Value="Model.SortOrder" />
            <ValidationMessage For="@(() => Model.SortOrder)" />
        </label>

        @if (ShowStatusToggles)
        {
            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsPublished" />
                <span>Published</span>
            </label>

            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsActive" />
                <span>Active</span>
            </label>
        }
    </div>

    <div class="actions">
        <button class="button primary" type="submit" disabled="@IsSaving">@SubmitText</button>
        <a class="button" href="@AdminRoutes.Lessons.Index">Cancel</a>
    </div>
</EditForm>

@code {
    private static readonly string[] CefrLevels = ["A1", "A2", "B1", "B2", "C1", "C2"];

    [Parameter, EditorRequired]
    public LessonFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyCollection<CategoryDto> Categories { get; set; } = [];

    [Parameter]
    public IReadOnlyCollection<MediaDto> ThumbnailMediaOptions { get; set; } = [];

    [Parameter]
    public IReadOnlyDictionary<string, string[]> ValidationErrors { get; set; } =
        new Dictionary<string, string[]>();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowStatusToggles { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    private async Task SubmitAsync()
    {
        await OnValidSubmit.InvokeAsync();
    }
}

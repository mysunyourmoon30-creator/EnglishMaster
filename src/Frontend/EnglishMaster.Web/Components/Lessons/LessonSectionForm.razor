@using EnglishMaster.Web.Services.Lessons

<EditForm Model="Model" OnValidSubmit="SubmitAsync" class="word-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ValidationErrors.Count > 0)
    {
        <div class="alert error">
            <ul>
                @foreach (var error in ValidationErrors.SelectMany(item => item.Value))
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-grid">
        <label class="span-2">
            <span>Title</span>
            <InputText class="input" @bind-Value="Model.Title" />
            <ValidationMessage For="@(() => Model.Title)" />
        </label>

        <label>
            <span>Section Type</span>
            <InputSelect class="input" @bind-Value="Model.SectionType">
                @foreach (var sectionType in SectionTypes)
                {
                    <option value="@sectionType">@sectionType</option>
                }
            </InputSelect>
        </label>

        <label>
            <span>Media</span>
            <InputSelect class="input" @bind-Value="Model.MediaId">
                <option value="">No media</option>
                @foreach (var media in MediaOptions)
                {
                    <option value="@media.Id">@media.OriginalFileName</option>
                }
            </InputSelect>
        </label>

        <label class="span-2">
            <span>Content (Markdown)</span>
            <InputTextArea class="input textarea" @bind-Value="Model.ContentMarkdown" />
            <ValidationMessage For="@(() => Model.ContentMarkdown)" />
        </label>

        <label>
            <span>Sort Order</span>
            <InputNumber class="input" @bind-Value="Model.SortOrder" />
            <ValidationMessage For="@(() => Model.SortOrder)" />
        </label>

        @if (ShowActiveToggle)
        {
            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsActive" />
                <span>Active</span>
            </label>
        }
    </div>

    <div class="actions">
        <button class="button primary" type="submit" disabled="@IsSaving">@SubmitText</button>
        <button class="button" type="button" @onclick="CancelAsync">Cancel</button>
    </div>
</EditForm>

@code {
    private static readonly string[] SectionTypes =
    [
        "Text", "Vocabulary", "Grammar", "Pronunciation", "Listening",
        "Speaking", "Reading", "Writing", "Practice", "Summary"
    ];

    [Parameter, EditorRequired]
    public LessonSectionFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyCollection<MediaDto> MediaOptions { get; set; } = [];

    [Parameter]
    public IReadOnlyDictionary<string, string[]> ValidationErrors { get; set; } =
        new Dictionary<string, string[]>();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowActiveToggle { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task SubmitAsync()
    {
        await OnValidSubmit.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        await OnCancel.InvokeAsync();
    }
}

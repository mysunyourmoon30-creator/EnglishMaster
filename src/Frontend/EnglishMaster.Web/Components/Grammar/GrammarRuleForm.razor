@using EnglishMaster.Web.Services.Grammar

<EditForm Model="Model" OnValidSubmit="SubmitAsync" class="word-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ValidationErrors.Count > 0)
    {
        <div class="alert error">
            <ul>
                @foreach (var error in ValidationErrors.SelectMany(item => item.Value))
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-grid">
        <label class="span-2">
            <span>Topic</span>
            <InputSelect class="input" @bind-Value="Model.GrammarTopicId">
                <option value="">Select topic</option>
                @foreach (var topic in Topics)
                {
                    <option value="@topic.Id">@topic.Title (@topic.CefrLevel)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.GrammarTopicId)" />
        </label>

        <label class="span-2">
            <span>Title</span>
            <InputText class="input" @bind-Value="Model.Title" />
            <ValidationMessage For="@(() => Model.Title)" />
        </label>

        <label class="span-2">
            <span>Rule Text</span>
            <InputTextArea class="input textarea" @bind-Value="Model.RuleText" />
            <ValidationMessage For="@(() => Model.RuleText)" />
        </label>

        <label class="span-2">
            <span>Structure Pattern</span>
            <InputTextArea class="input textarea" @bind-Value="Model.StructurePattern" />
            <ValidationMessage For="@(() => Model.StructurePattern)" />
        </label>

        <label class="span-2">
            <span>Thai Explanation</span>
            <InputTextArea class="input textarea" @bind-Value="Model.ExplanationTh" />
            <ValidationMessage For="@(() => Model.ExplanationTh)" />
        </label>

        <label class="span-2">
            <span>English Explanation</span>
            <InputTextArea class="input textarea" @bind-Value="Model.ExplanationEn" />
            <ValidationMessage For="@(() => Model.ExplanationEn)" />
        </label>

        <label class="span-2">
            <span>Common Mistake</span>
            <InputTextArea class="input textarea" @bind-Value="Model.CommonMistake" />
            <ValidationMessage For="@(() => Model.CommonMistake)" />
        </label>

        <label class="span-2">
            <span>Correct Usage Note</span>
            <InputTextArea class="input textarea" @bind-Value="Model.CorrectUsageNote" />
            <ValidationMessage For="@(() => Model.CorrectUsageNote)" />
        </label>

        <label>
            <span>Sort Order</span>
            <InputNumber class="input" @bind-Value="Model.SortOrder" />
            <ValidationMessage For="@(() => Model.SortOrder)" />
        </label>

        @if (ShowActiveToggle)
        {
            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsActive" />
                <span>Active</span>
            </label>
        }
    </div>

    <div class="actions">
        <button class="button primary" type="submit" disabled="@IsSaving">@SubmitText</button>
        <a class="button" href="@CancelHref">Cancel</a>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public GrammarRuleFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyCollection<GrammarTopicDto> Topics { get; set; } = [];

    [Parameter]
    public IReadOnlyDictionary<string, string[]> ValidationErrors { get; set; } =
        new Dictionary<string, string[]>();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowActiveToggle { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public string CancelHref { get; set; } = AdminRoutes.GrammarRules.Index;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    private async Task SubmitAsync()
    {
        await OnValidSubmit.InvokeAsync();
    }
}

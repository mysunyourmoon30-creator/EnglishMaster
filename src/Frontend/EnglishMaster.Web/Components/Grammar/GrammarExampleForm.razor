@using EnglishMaster.Web.Services.Grammar

<EditForm Model="Model" OnValidSubmit="SubmitAsync" class="word-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ValidationErrors.Count > 0)
    {
        <div class="alert error">
            <ul>
                @foreach (var error in ValidationErrors.SelectMany(item => item.Value))
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-grid">
        <label class="span-2">
            <span>Example</span>
            <InputTextArea class="input textarea" @bind-Value="Model.ExampleEn" />
            <ValidationMessage For="@(() => Model.ExampleEn)" />
        </label>

        <label class="span-2">
            <span>Thai Translation</span>
            <InputTextArea class="input textarea" @bind-Value="Model.TranslationTh" />
            <ValidationMessage For="@(() => Model.TranslationTh)" />
        </label>

        <label class="span-2">
            <span>Thai Explanation</span>
            <InputTextArea class="input textarea" @bind-Value="Model.ExplanationTh" />
            <ValidationMessage For="@(() => Model.ExplanationTh)" />
        </label>

        <label>
            <span>Sort Order</span>
            <InputNumber class="input" @bind-Value="Model.SortOrder" />
            <ValidationMessage For="@(() => Model.SortOrder)" />
        </label>

        <label class="checkbox-row">
            <InputCheckbox @bind-Value="Model.IsCorrectExample" />
            <span>Correct Example</span>
        </label>

        @if (ShowActiveToggle)
        {
            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsActive" />
                <span>Active</span>
            </label>
        }
    </div>

    <div class="actions">
        <button class="button primary" type="submit" disabled="@IsSaving">@SubmitText</button>
        <button class="button" type="button" @onclick="CancelAsync">Cancel</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public GrammarExampleFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyDictionary<string, string[]> ValidationErrors { get; set; } =
        new Dictionary<string, string[]>();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowActiveToggle { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task SubmitAsync()
    {
        await OnValidSubmit.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        await OnCancel.InvokeAsync();
    }
}

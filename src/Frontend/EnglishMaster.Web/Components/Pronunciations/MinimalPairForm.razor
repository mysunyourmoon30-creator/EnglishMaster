@using EnglishMaster.Web.Services.Pronunciations

<EditForm Model="Model" OnValidSubmit="SubmitAsync" class="word-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (ValidationErrors.Count > 0)
    {
        <div class="alert error">
            <ul>
                @foreach (var error in ValidationErrors.SelectMany(item => item.Value))
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-grid">
        <label>
            <span>Pair Word</span>
            <InputText class="input" @bind-Value="Model.PairWordText" />
            <ValidationMessage For="@(() => Model.PairWordText)" />
        </label>

        <label>
            <span>Pair IPA</span>
            <InputText class="input" @bind-Value="Model.PairIpa" />
            <ValidationMessage For="@(() => Model.PairIpa)" />
        </label>

        <label>
            <span>Thai Reading</span>
            <InputText class="input" @bind-Value="Model.PairThaiReading" />
            <ValidationMessage For="@(() => Model.PairThaiReading)" />
        </label>

        <label>
            <span>Sort Order</span>
            <InputNumber class="input" @bind-Value="Model.SortOrder" />
            <ValidationMessage For="@(() => Model.SortOrder)" />
        </label>

        <label class="span-2">
            <span>Audio</span>
            <InputSelect class="input" @bind-Value="Model.AudioMediaId">
                <option value="">No audio</option>
                @foreach (var media in AudioMedia)
                {
                    <option value="@media.Id">@media.OriginalFileName</option>
                }
            </InputSelect>
        </label>

        <label class="span-2">
            <span>Difference Note</span>
            <InputTextArea class="input textarea" @bind-Value="Model.DifferenceNote" />
            <ValidationMessage For="@(() => Model.DifferenceNote)" />
        </label>

        @if (ShowActiveToggle)
        {
            <label class="checkbox-row">
                <InputCheckbox @bind-Value="Model.IsActive" />
                <span>Active</span>
            </label>
        }
    </div>

    <div class="actions">
        <button class="button primary" type="submit" disabled="@IsSaving">@SubmitText</button>
        @if (OnCancel.HasDelegate)
        {
            <button class="button" type="button" @onclick="CancelAsync">Cancel</button>
        }
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public MinimalPairFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyCollection<MediaDto> AudioMedia { get; set; } = [];

    [Parameter]
    public IReadOnlyDictionary<string, string[]> ValidationErrors { get; set; } =
        new Dictionary<string, string[]>();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowActiveToggle { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = "Save";

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task SubmitAsync()
    {
        await OnValidSubmit.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        await OnCancel.InvokeAsync();
    }
}
